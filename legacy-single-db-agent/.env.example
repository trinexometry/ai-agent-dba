# Oracle connection settings
ORACLE_DSN=localhost:1521/FREEPDB1
ORACLE_USER=system
ORACLE_PASSWORD=change-me

# Optional. Valid examples: SYSDBA, SYSOPER. Leave empty for normal login.
ORACLE_MODE=

# Optional. Required only when using --llm openai for report analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
